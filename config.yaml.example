# GitHub Token (required)
github_token: your_github_token_here
github_username: your_github_username

# Gitea backup (optional)
gitea:
  url: http://localhost:3000
  token: your_gitea_token_here
  username: your_gitea_username

# LLM Configuration (supports Anthropic, OpenAI, Ollama)
llm:
  provider: anthropic          # anthropic | openai | ollama
  api_key: your_api_key_here  # API Key for the provider
  model: claude-sonnet-4-20250514  # Model name
  base_url: ""                # Custom base URL (for OpenAI compatible APIs)

# Embedder Configuration
embedder:
  provider: sentence-transformers  # sentence-transformers | openai | cohere | ollama
  model: all-MiniLM-L6-v2
  api_key: ""
  base_url: ""                # Custom base URL (for Ollama)

# Text splitting
text_split:
  chunk_size: 1024
  chunk_overlap: 128

# Local SQLite database
database:
  path: ~/.github-star-mcp/data.db

# Server configuration
server:
  mode: guided          # guided | mcp (guided = web UI + MCP, mcp = HTTP MCP only)
  host: 0.0.0.0
  port: 8080
  require_sync: true     # Block MCP until sync completes
