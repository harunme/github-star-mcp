# GitHub Token (required)
github_token: your_github_token_here
github_username: your_github_username

# Gitea backup (optional)
gitea:
  url: http://localhost:3000
  token: your_gitea_token_here
  username: your_gitea_username

# Anthropic API for RAG (optional)
anthropic_api_key: your_anthropic_api_key_here
anthropic_model: claude-sonnet-4-20250514

# Local SQLite database
database:
  path: ~/.github-star-mcp/data.db

# Server configuration
server:
  mode: guided          # guided | mcp (guided = web UI + MCP, mcp = HTTP MCP only)
  host: 0.0.0.0
  port: 8080
  require_sync: true     # Block MCP until sync completes
